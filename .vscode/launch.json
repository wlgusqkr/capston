{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Django: runserver (venv) — mac/linux 기본",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/backend/manage.py",
      "args": ["runserver", "127.0.0.1:8000", "--noreload"],
      "cwd": "${workspaceFolder}/backend",
      "python": "${command:python.interpreterPath}",
      "envFile": "${workspaceFolder}/backend/.env",
      "django": true,
      "justMyCode": false,
      "console": "integratedTerminal"
    },
    {
      "name": "Attach to Django (docker) — windows 권장",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/backend",
          "remoteRoot": "/app"
        }
      ],
      "justMyCode": true
    }
  ]
}
