# Vite는 VITE_ 프리픽스가 붙은 변수만 클라이언트에 노출됩니다.
# 실제 .env는 git ignore — 이 파일을 복사: cp frontend/.env.example frontend/.env

# Backend API base URL (docker-compose dev 기준 — backend가 8000에 떠있음)
VITE_API_BASE_URL=http://localhost:8000/api

# VWorld 지도 타일 (필수 — 비어있으면 지도 타일이 안 떠요)
# 발급: https://www.vworld.kr/  → 인증키 신청 → localhost 도메인 등록한 키
VITE_VWORLD_API_KEY=

# 카카오 JS 키 (시간 남으면 사용)
VITE_KAKAO_JS_KEY=2bbd4c163ff7f3f5023f15a9678ff96c
