# SLGI frontend .env 템플릿 (DP_DB 통합용)
#
# 사용법:
#   1) 본 파일을 .env로 복사 후 값을 채운다.
#   2) Vite는 VITE_ 프리픽스가 붙은 변수만 클라이언트에 노출한다.
#   3) 실제 .env는 git ignore.

# Backend API base URL (SLGI backend가 8000번에 떠있음)
VITE_API_BASE_URL=http://localhost:8000/api

# VWorld 지도 타일 키 (필수 — 비어있으면 지도 타일이 안 뜸)
# 발급: https://www.vworld.kr/ → 인증키 신청 → localhost 도메인 등록
VITE_VWORLD_API_KEY=<VWorld 인증키>

# 카카오 JavaScript key
VITE_KAKAO_JS_KEY=<카카오 JavaScript key>
