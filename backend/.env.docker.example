# Docker 실행용 백엔드 .env 템플릿. (Windows 권장 — GDAL 설치 우회)
# mac/linux는 .env.example(venv)를 쓰는 게 디버깅이 더 부드럽습니다.
#
# 사용:
#   cp backend/.env.docker.example backend/.env
#   <YOUR_USER>/<YOUR_PASSWORD> 채우기 (1Password)
#   ssh -N -L 5432:127.0.0.1:5432 parkparkjihyeon@<ZeroTier-IP>   # 다른 창 (모드 1만)
#   docker compose up -d
#
# VSCode 디버거: docker compose stop backend → 별도 명령으로 debugpy 띄우고
# F5 → "Attach to Django (docker)"

# Django core
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ────────────────────────────────────────────────────────────────
# 기본: 운영 DB 사용 (호스트의 SSH 터널을 컨테이너에서 host.docker.internal로 접근).
DATABASE_URL=postgis://<YOUR_USER>:<YOUR_PASSWORD>@host.docker.internal:5432/slgi

# 대안: docker-compose의 db 서비스 사용. 위 줄 주석 처리하고 아래 줄 활성화 +
# docker compose --profile local-db up -d (db도 같이 기동).
# DATABASE_URL=postgis://slgi:slgi@db:5432/slgi

# ─── Redis ────────────────────────────────────────────────────────────────────
# docker-compose의 redis 서비스 사용 (컨테이너 네트워크 내부 이름).
REDIS_URL=redis://redis:6379/0

# CORS — frontend dev server (Vite)
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# GeoDjango — Dockerfile.dev에 GDAL이 깔려 있으므로 경로 지정 불필요.

# 카카오 소셜 로그인 (시간 남으면 사용)
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/api/auth/kakao/callback

# 공공 데이터 API 키 (ops만 채우면 됨)
DATA_GO_KR_API_KEY=
SEOUL_OPEN_API_KEY=
VWORLD_API_KEY=
