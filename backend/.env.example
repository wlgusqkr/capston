# SLGI backend .env 템플릿
#
# 사용법:
#   1) 본 파일을 .env로 복사 후 값을 채운다.
#   2) 모든 secret/key 값은 placeholder. 직접 채워야 동작한다.
#
# 보안:
#   - 본 .env.example 파일은 git 추적 가능 (placeholder만 포함).
#   - 실제 .env 파일은 git ignore. 평문 secret 절대 커밋 금지.

# ─── Django core ─────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=<replace-with-random-50-chars>
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database (SLGI 자체 PostGIS 컨테이너) ─────────────────────
DATABASE_URL=postgis://slgi:slgi@db:5432/slgi

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── CORS ────────────────────────────────────────────────────
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── 외부 API (DP_DB User scope env 값 그대로 복사) ────────────
PUBLIC_DATA_API_KEY=
SEOUL_API_KEY=
V_WORLD_API_KEY=
KOSIS_API_KEY=

# ─── Kakao 소셜 로그인 (현재 비활성, 추후 활성화 시 채움) ──────
# KAKAO_REST_API_KEY=
# KAKAO_CLIENT_SECRET=
# KAKAO_REDIRECT_URI=http://localhost:8000/api/auth/kakao/callback
