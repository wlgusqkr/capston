# 로컬 개발용 백엔드 .env 템플릿.
# 실제 .env는 git ignore — 이 파일을 복사: cp backend/.env.example backend/.env

# Django core
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ────────────────────────────────────────────────────────────────
# 기본: 운영 DB 사용 (홈서버의 postgres). 사전 조건:
#   1) ZeroTier 합류 + Auth 완료
#   2) SSH 터널이 켜져있음:
#      ssh -N -L 5432:127.0.0.1:5432 parkparkjihyeon@<ZeroTier IP>
#   3) <YOUR_USER>/<YOUR_PASSWORD>는 ops가 발급해준 본인 DB 계정 (1Password로 전달됨)
# host.docker.internal: docker 컨테이너 안에서 호스트의 127.0.0.1을 가리킴 (Win/Mac).
DATABASE_URL=postgis://<YOUR_USER>:<YOUR_PASSWORD>@host.docker.internal:5432/slgi

# 대안: 완전 로컬 DB (운영 DB 안 쓰고 빈 db로 작업할 때만).
# 위 줄 주석 처리하고 아래 줄 주석 해제, docker compose에 db 서비스도 같이 띄우세요.
# DATABASE_URL=postgis://slgi:slgi@db:5432/slgi

# ─── Redis ────────────────────────────────────────────────────────────────────
# Redis는 캐시 용도라 로컬 컨테이너 그대로 사용 (운영 redis 굳이 안 씀).
REDIS_URL=redis://redis:6379/0

# CORS — frontend dev server (Vite)
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# GeoDjango — 호스트에서 직접 실행 시 GDAL/GEOS 경로. docker 안에선 불필요.
# macOS Homebrew 예시:
# GDAL_LIBRARY_PATH=/opt/homebrew/opt/gdal/lib/libgdal.dylib
# GEOS_LIBRARY_PATH=/opt/homebrew/opt/geos/lib/libgeos_c.dylib

# 카카오 소셜 로그인 (시간 남으면 사용)
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/api/auth/kakao/callback

# 공공 데이터 API 키 (data-pipeline 단계에서 사용 — ops만 채우면 됨, 일반 dev는 비워둬도 OK)
DATA_GO_KR_API_KEY=
SEOUL_OPEN_API_KEY=
VWORLD_API_KEY=
