# 로컬 개발용 백엔드 .env 템플릿.
# 실제 .env는 git ignore — 이 파일을 복사: cp backend/.env.example backend/.env

# Django core
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database — docker-compose 기준 (backend 컨테이너에서 db 서비스로 접속)
# 호스트에서 직접 manage.py 돌릴 거면 db→localhost, 5432→5433 으로 바꾸세요.
DATABASE_URL=postgis://slgi:slgi@db:5432/slgi

# Redis — docker-compose 기준
REDIS_URL=redis://redis:6379/0

# CORS — frontend dev server (Vite)
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# GeoDjango — 호스트에서 직접 실행 시 GDAL/GEOS 경로. docker 안에선 불필요.
# macOS Homebrew 예시:
# GDAL_LIBRARY_PATH=/opt/homebrew/opt/gdal/lib/libgdal.dylib
# GEOS_LIBRARY_PATH=/opt/homebrew/opt/geos/lib/libgeos_c.dylib

# 카카오 소셜 로그인 (시간 남으면 사용)
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/api/auth/kakao/callback

# 공공 데이터 API 키 (data-pipeline 단계에서 사용)
# data.go.kr 인증키 1개로 국토부 실거래가(전월세) + 소상공인 상가정보 둘 다 사용.
# 데이터셋별 활용신청만 따로 (15126473/72/75 + 15012005).
DATA_GO_KR_API_KEY=
SEOUL_OPEN_API_KEY=
VWORLD_API_KEY=
