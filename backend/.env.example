# 로컬 venv 실행용 백엔드 .env 템플릿. (mac/linux 기본 권장 경로)
# Windows 팀원은 .env.docker.example을 쓰세요 (GDAL 설치 우회).
#
# 사용:
#   cp backend/.env.example backend/.env
#   <YOUR_USER>/<YOUR_PASSWORD> 채우기 (1Password)
#   ssh -N -L 5432:127.0.0.1:5432 parkparkjihyeon@<ZeroTier-IP>   # 다른 창
#   cd backend && uv sync && uv run python manage.py runserver
#
# VSCode 디버거: F5 → "Django: runserver (venv)" 선택

# Django core
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ────────────────────────────────────────────────────────────────
# 기본: 운영 DB 사용 (홈서버 postgres, SSH 터널 경유). 사전 조건:
#   1) ZeroTier 합류 + Auth 완료
#   2) SSH 터널: ssh -N -L 5432:127.0.0.1:5432 parkparkjihyeon@<ZeroTier IP>
#   3) <YOUR_USER>/<YOUR_PASSWORD> = ops가 발급해준 본인 DB 계정
DATABASE_URL=postgis://<YOUR_USER>:<YOUR_PASSWORD>@127.0.0.1:5432/slgi

# 대안: 완전 로컬 DB (오프라인 / migrate 테스트). 위 줄 주석 처리하고 아래 줄 활성화 +
# 다른 창에서: docker compose --profile local-db up -d db
# 호스트 포트 5433으로 매핑되어 있음 (5432가 터널과 충돌 방지).
# DATABASE_URL=postgis://slgi:slgi@127.0.0.1:5433/slgi

# ─── Redis ────────────────────────────────────────────────────────────────────
# 로컬 docker redis 사용 (docker compose up -d redis로 띄움).
REDIS_URL=redis://127.0.0.1:6379/0

# CORS — frontend dev server (Vite)
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── GeoDjango (호스트 venv 실행 시 필수) ─────────────────────────────────────
# Django 5.1 GDAL 자동 탐지가 Homebrew 3.12를 못 찾아서 명시 필요.
# macOS Apple Silicon (Homebrew):
GDAL_LIBRARY_PATH=/opt/homebrew/opt/gdal/lib/libgdal.dylib
GEOS_LIBRARY_PATH=/opt/homebrew/opt/geos/lib/libgeos_c.dylib
# macOS Intel: /usr/local/opt/gdal/lib/libgdal.dylib
# Linux: 보통 자동 탐지됨. 안 되면 ldconfig -p | grep gdal로 경로 확인.

# 카카오 소셜 로그인 (시간 남으면 사용)
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/api/auth/kakao/callback

# 공공 데이터 API 키 (data-pipeline 단계에서 사용 — ops만 채우면 됨)
DATA_GO_KR_API_KEY=
SEOUL_OPEN_API_KEY=
VWORLD_API_KEY=
