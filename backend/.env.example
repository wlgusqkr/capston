# Django core
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (matches docker-compose.yml defaults for local dev)
DATABASE_URL=postgis://slgi:slgi@localhost:5433/slgi

# GeoDjango — macOS Homebrew GDAL 경로 명시 (Django 5.1 GDAL 3.12 자동 탐지 X)
# 자동 탐지 안 될 때만 사용. Linux는 보통 비워두면 됨.
GDAL_LIBRARY_PATH=/opt/homebrew/opt/gdal/lib/libgdal.dylib
GEOS_LIBRARY_PATH=/opt/homebrew/opt/geos/lib/libgeos_c.dylib

# CORS — frontend dev server
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Cache (선택, 5분 캐싱용 — SPEC 14.3)
REDIS_URL=redis://localhost:6379/0

# 카카오 소셜 로그인 (시간 남으면 사용)
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/api/auth/kakao/callback

# 공공 데이터 API 키 (data-pipeline 단계에서 사용)
MOLIT_API_KEY=
SBA_API_KEY=
SEOUL_OPEN_API_KEY=
VWORLD_API_KEY=
