# 풀 로컬 모드 — docker로 db까지 같이 띄우는 오프라인 dev.
# SSH 터널/ZeroTier 없이 동작. migrate/모델 변경 테스트할 때 권장.
#
# 사용:
#   cp backend/.env.local.example backend/.env
#   docker compose --profile local-db up -d
#   cd frontend && npm run dev

# Django core
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=dev-only-please-change
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database — docker-compose의 db 서비스 사용 (--profile local-db로 같이 기동)
DATABASE_URL=postgis://slgi:slgi@db:5432/slgi

# Redis — docker-compose의 redis 서비스
REDIS_URL=redis://redis:6379/0

# 카카오 (시간 남으면)
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/api/auth/kakao/callback

# 외부 API — 로컬 dev에선 비워둬도 OK (더미 모드)
DATA_GO_KR_API_KEY=
SEOUL_OPEN_API_KEY=
VWORLD_API_KEY=
